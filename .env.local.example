# Angela App — example environment file
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Database (Phase 1)
DATABASE_URL=data/angela.db

# better-auth (Phase 1)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Anthropic Claude API — Phase 2 (D-22)
# Get a key from https://console.anthropic.com/settings/keys
# Never commit the actual value.
ANTHROPIC_API_KEY=

# Optional — FX rate for audit-only cost logging in extraction_log (D-15).
# Default 0.92 EUR/USD. Set explicitly for accurate accounting.
USD_TO_EUR=0.92
