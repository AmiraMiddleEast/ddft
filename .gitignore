# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Data directory (SQLite + future uploads)
data/*
!data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm

# Phase 2 — uploaded PDFs (D-06: data/uploads/{uuid}.pdf, never committed)
# Re-include the uploads directory so .gitkeep can be tracked (parent data/* rule above excludes it).
!data/uploads/
data/uploads/*
!data/uploads/.gitkeep

# Drizzle
drizzle/.migrations-lock.json
